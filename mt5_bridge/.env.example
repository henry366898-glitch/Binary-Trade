# ─── MT5 Credentials ─────────────────────────────────────────────────────────
# Your broker demo/live account credentials.
# Leave blank if the MT5 terminal is already logged in manually.
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Demo

# Full path to terminal64.exe — only needed if MT5 is not in the default location
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ─── Symbols ─────────────────────────────────────────────────────────────────
# Comma-separated list. Must match exactly what your broker exposes.
# Common alternatives: XAUUSD vs GOLD, BTCUSD vs BTCUSDT
SYMBOLS=EURUSD,GBPUSD,USDJPY,XAUUSD,BTCUSD,ETHUSD

# ─── Polling ─────────────────────────────────────────────────────────────────
# How often to poll MT5 for new ticks (milliseconds).
# 250ms = 4 ticks/second per symbol. Lower = more CPU. Don't go below 100.
TICK_POLL_MS=250

# ─── WebSocket Server ────────────────────────────────────────────────────────
# Host and port the bridge listens on.
# 0.0.0.0 = accept connections from any IP (required so the backend can connect).
# Change BRIDGE_PORT if 9000 is already in use.
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=9000

# ─── Test App ─────────────────────────────────────────────────────────────────
# Port for the FastAPI diagnostic UI (test_app.py).
# Open http://<this-machine-ip>:9001 in a browser to see live ticks.
TEST_PORT=9001
